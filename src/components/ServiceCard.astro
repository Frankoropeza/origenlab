---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<div class="service-card">
  <!-- Imagen placeholder -->
  <div class="service-img">
    <span class="service-img__label">Imagen próximamente</span>
  </div>

  <div class="service-body">
    <h3 class="service-title">{title}</h3>
    <p class="service-desc">{description}</p>
    <a href={href} class="service-btn">Más información →</a>
  </div>
</div>

<style>
  .service-card {
    background: var(--bg-alt);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.1);
  }

  /* Placeholder imagen 16:9 */
  .service-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #E0E0E5;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .service-img__label {
    font-size: 12px;
    color: #999;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* Contenido */
  .service-body {
    padding: 2rem 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 0.75rem;
  }

  .service-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0;
  }

  .service-desc {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
    flex-grow: 1;
  }

  /* Botón real */
  .service-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.75rem;
    padding: 0.65rem 1.5rem;
    background: var(--accent);
    color: #fff;
    border-radius: 980px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    align-self: flex-start;
    transition: background 0.2s, transform 0.2s;
  }

  .service-btn:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .service-body {
      padding: 1.5rem;
    }
  }
</style>
