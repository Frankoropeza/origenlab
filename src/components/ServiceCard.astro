---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}

const { title, description, icon, href } = Astro.props;
---

<a href={href} class="service-card">
  <span class="service-icon">{icon}</span>
  <h3 class="service-title">{title}</h3>
  <p class="service-desc">{description}</p>
  <span class="service-link">Más información →</span>
</a>

<style>
  .service-card {
    background: var(--bg-alt);
    border-radius: 20px;
    padding: 48px;
    display: flex;
    flex-direction: column;
    color: var(--text);
    transition: background 0.3s var(--ease), transform 0.3s var(--ease);
  }

  .service-card:hover {
    background: #E8E8ED;
    transform: scale(1.01);
    color: var(--text);
  }

  .service-icon {
    font-size: 48px;
    margin-bottom: 1.5rem;
    display: block;
    line-height: 1;
  }

  .service-title {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .service-desc {
    font-size: 17px;
    color: var(--text-muted);
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: 1.5rem;
  }

  .service-link {
    font-size: 14px;
    color: var(--accent);
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .service-card {
      padding: 32px;
    }

    .service-title {
      font-size: 22px;
    }

    .service-desc {
      font-size: 15px;
    }
  }
</style>
