---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<div class="sc">
  <div class="sc__img">
    <span>Imagen próximamente</span>
  </div>
  <div class="sc__body">
    <h3 class="sc__title">{title}</h3>
    <p class="sc__desc">{description}</p>
    <a href={href} class="sc__btn">{title}</a>
  </div>
</div>

<style>
  .sc {
    background: var(--bg-alt);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
  }

  /* Placeholder imagen */
  .sc__img {
    width: 100%;
    aspect-ratio: 16/9;
    background: #DDDDE3;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .sc__img span {
    font-size: 11px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Cuerpo */
  .sc__body {
    padding: 1.25rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex-grow: 1;
  }
  .sc__title {
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0;
  }
  .sc__desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
    flex-grow: 1;
  }

  /* Botón real */
  .sc__btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.55rem 1.25rem;
    background: var(--accent);
    color: #ffffff !important;
    border-radius: 980px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    align-self: flex-start;
    border: none;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
    line-height: 1.4;
  }
  .sc__btn:hover {
    background: var(--accent-hover);
    color: #ffffff !important;
    text-decoration: none;
  }
</style>
