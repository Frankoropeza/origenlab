<style>
  .topbar {
    background: #1D1D1F;
    height: var(--topbar-height);
    display: flex;
    align-items: center;
    font-size: 12px;
    color: rgba(255,255,255,0.8);
  }

  .topbar-inner {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .topbar-content {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .topbar-sep {
    color: rgba(255,255,255,0.3);
  }

  .topbar-link {
    color: rgba(255,255,255,0.8);
    transition: color 0.2s;
  }

  .topbar-link:hover {
    color: #fff;
  }

  .topbar-wa {
    color: var(--accent);
  }

  .topbar-wa:hover {
    color: #3d9bff;
  }

  .topbar-info {
    color: rgba(255,255,255,0.5);
  }

  @media (max-width: 640px) {
    .topbar-info,
    .topbar-sep:last-of-type {
      display: none;
    }
  }
</style>
