---
interface Props {
  name: string;
  company: string;
  text: string;
  role: string;
}

const { name, company, text, role } = Astro.props;

// Iniciales para el placeholder circular
const initials = name.split(" ").map((n: string) => n[0]).slice(0, 2).join("");
---

<div class="tc">

  <!-- Cuerpo: estrellas + texto -->
  <div class="tc__body">
    <div class="tc__stars">
      <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
    </div>
    <p class="tc__text">{text}</p>
  </div>

  <!-- Footer: avatar + nombre -->
  <div class="tc__footer">
    <div class="tc__avatar" aria-hidden="true">
      {initials}
    </div>
    <div class="tc__info">
      <p class="tc__name">{name}</p>
      <p class="tc__role">{role} · {company}</p>
    </div>
  </div>

</div>

<style>
  .tc {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* ── Estrellas ── */
  .tc__stars {
    display: flex;
    gap: 2px;
    margin-bottom: 0.875rem;
  }
  .tc__stars span {
    color: #F59E0B;
    font-size: 14px;
  }

  /* ── Texto ── */
  .tc__text {
    font-size: 15px;
    color: var(--text);
    line-height: 1.75;
    margin: 0;
  }

  /* ── Footer ── */
  .tc__footer {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  /* Avatar circular con iniciales */
  .tc__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
    letter-spacing: 0.5px;
    /* Cuando haya foto real: reemplazar background por <img> */
  }

  .tc__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tc__name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }

  .tc__role {
    font-size: 12px;
    color: var(--text-muted);
    margin: 0;
  }
</style>
