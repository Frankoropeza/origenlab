---
interface Props {
  name: string;
  company: string;
  text: string;
  role: string;
}

const { name, company, text, role } = Astro.props;
---

<div class="testimonial-card">
  <span class="testimonial-quote">"</span>
  <p class="testimonial-text">{text}</p>
  <div class="testimonial-author">
    <p class="testimonial-name">{name}</p>
    <p class="testimonial-role">{role}, {company}</p>
  </div>
</div>

<style>
  .testimonial-card {
    background: var(--bg-alt);
    border-radius: 16px;
    padding: 2rem;
    position: relative;
  }

  .testimonial-quote {
    font-size: 48px;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.3;
    line-height: 1;
    display: block;
    margin-bottom: 0.5rem;
  }

  .testimonial-text {
    font-size: 15px;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .testimonial-name {
    font-weight: 600;
    font-size: 15px;
    color: var(--text);
  }

  .testimonial-role {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 2px;
  }
</style>
