---
const year = new Date().getFullYear();

const servicios = [
  { href: "/servicios/desarrollo-web/", label: "Desarrollo Web" },
  { href: "/servicios/tiendas-en-linea/", label: "Tiendas en Línea" },
  { href: "/servicios/landing-pages/", label: "Landing Pages" },
  { href: "/servicios/seo-posicionamiento/", label: "SEO y Posicionamiento" },
];

const empresa = [
  { href: "/nosotros/", label: "Nosotros" },
  { href: "/portafolio/", label: "Portafolio" },
  { href: "/blog/", label: "Blog" },
  { href: "/cotizar/", label: "Cotizar proyecto" },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <span class="footer-logo">OrigenLab<span class="logo-dot">·</span></span>
        <p class="footer-desc">Agencia de desarrollo web profesional en México. Sitios rápidos, modernos y optimizados para SEO.</p>
      </div>

      <div class="footer-col">
        <h4 class="footer-heading">Servicios</h4>
        <ul>
          {servicios.map((s) => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-heading">Empresa</h4>
        <ul>
          {empresa.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-heading">Legal</h4>
        <ul>
          <li><a href="/contacto/">Aviso de privacidad</a></li>
          <li><a href="/contacto/">Términos de servicio</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-heading">Contacto</h4>
        <ul>
          <li><a href="mailto:hola@origenlab.mx">hola@origenlab.mx</a></li>
          <li><a href="https://wa.me/5255XXXXXXXX" target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
          <li><span class="footer-location">Ciudad de México, MX</span></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} OrigenLab. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-alt);
    border-top: 1px solid #D2D2D7;
    padding: 3rem 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text);
  }

  .logo-dot {
    color: var(--accent);
    margin-left: 1px;
  }

  .footer-desc {
    margin-top: 0.75rem;
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .footer-heading {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    color: var(--text-muted);
    font-size: 13px;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: var(--text);
  }

  .footer-location {
    color: var(--text-muted);
    font-size: 13px;
  }

  .footer-bottom {
    border-top: 1px solid #D2D2D7;
    padding-top: 1.5rem;
    text-align: center;
  }

  .footer-bottom p {
    color: var(--text-muted);
    font-size: 13px;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
