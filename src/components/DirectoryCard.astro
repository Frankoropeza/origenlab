---
interface Props {
  name: string;
  giro: string;
  zone: string;
  description: string;
  mapsUrl?: string;
  hasWebsite: boolean;
}

const { name, giro, zone, description, mapsUrl, hasWebsite } = Astro.props;
const initials = name.split(" ").slice(0, 2).map(w => w[0]).join("").toUpperCase();
---

<div class="dc">
  <div class="dc__top">
    <div class="dc__avatar">{initials}</div>
    <div class="dc__badge-wrap">
      <span class="dc__giro">{giro}</span>
      {!hasWebsite && <span class="dc__no-web">Sin sitio web</span>}
    </div>
  </div>

  <div class="dc__body">
    <h3 class="dc__name">{name}</h3>
    <p class="dc__zone">📍 {zone}</p>
    <p class="dc__desc">{description}</p>
  </div>

  <div class="dc__footer">
    {mapsUrl && (
      <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="dc__maps-link">
        Ver en Google Maps →
      </a>
    )}
    <a href="/cotizar/?ref=directorio" class="dc__cta">
      ¿Es tu negocio? Consigue tu sitio →
    </a>
  </div>
</div>

<style>
  .dc {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .dc:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }

  .dc__top {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .dc__avatar {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.5px;
  }

  .dc__badge-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }

  .dc__giro {
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 980px;
    padding: 0.2rem 0.6rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .dc__no-web {
    font-size: 11px;
    font-weight: 500;
    color: #D97706;
    background: rgba(217, 119, 6, 0.08);
    border: 1px solid rgba(217, 119, 6, 0.2);
    border-radius: 980px;
    padding: 0.2rem 0.6rem;
  }

  .dc__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .dc__name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    line-height: 1.3;
  }

  .dc__zone {
    font-size: 12px;
    color: var(--text-muted);
    margin: 0;
  }

  .dc__desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0.25rem 0 0;
  }

  .dc__footer {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .dc__maps-link {
    font-size: 12px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .dc__maps-link:hover {
    color: var(--accent);
  }

  .dc__cta {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .dc__cta:hover {
    opacity: 0.75;
  }
</style>
