---
interface Props {
  ctaLabel?: string;
  ctaHref?: string;
}

const { ctaLabel = "Cotizar proyecto →", ctaHref = "/cotizar/" } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/servicios/", label: "Servicios", submenu: [
    { href: "/servicios/desarrollo-web/", label: "Desarrollo Web" },
    { href: "/servicios/tiendas-en-linea/", label: "Tiendas en Línea" },
    { href: "/servicios/landing-pages/", label: "Landing Pages" },
    { href: "/servicios/rediseno-web/", label: "Rediseño Web" },
  ]},
  { href: "/portafolio/", label: "Portafolio" },
  { href: "/nosotros/", label: "Nosotros" },
  { href: "/blog/", label: "Blog" },
  { href: "/contacto/", label: "Contacto" },
];
---

<header class="header" id="header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href="/" class="logo">
      OrigenLab<span class="logo-dot">·</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Navegación principal">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li class={link.submenu ? "has-dropdown" : ""}>
            <a
              href={link.href}
              class:list={["nav-link", { active: currentPath === link.href || (link.submenu && currentPath.startsWith("/servicios/")) }]}
            >
              {link.label}
              {link.submenu && <svg class="chevron-icon" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>}
            </a>
            {link.submenu && (
              <div class="dropdown">
                <ul class="dropdown-list">
                  {link.submenu.map((sub) => (
                    <li>
                      <a href={sub.href} class:list={["dropdown-link", { active: currentPath === sub.href }]}>
                        {sub.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop CTA -->
    <a href={ctaHref} class="btn btn-primary header-cta">{ctaLabel}</a>

    <!-- Hamburger -->
    <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
  </div>
</header>

<!-- Mobile overlay -->
<div class="mobile-overlay" id="mobileOverlay"></div>

<!-- Mobile panel -->
<nav class="mobile-panel" id="mobilePanel" aria-label="Menú móvil">
  <div class="mobile-panel-header">
    <span class="mobile-panel-title">Menú</span>
    <button class="mobile-close" id="mobileClose" aria-label="Cerrar menú">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <ul class="mobile-nav-list">
    {navLinks.map((link) => (
      <li class={link.submenu ? "mobile-has-sub" : ""}>
        {link.submenu ? (
          <>
            <button class="mobile-link mobile-sub-toggle" data-submenu>
              <span>{link.label}</span>
              <svg class="mobile-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <ul class="mobile-submenu">
              {link.submenu.map((sub) => (
                <li>
                  <a href={sub.href} class:list={["mobile-link mobile-sublink", { active: currentPath === sub.href }]}>
                    {sub.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        ) : (
          <a href={link.href} class:list={["mobile-link", { active: currentPath === link.href }]}>
            {link.label}
          </a>
        )}
      </li>
    ))}
  </ul>

  <div class="mobile-panel-footer">
    <a href={ctaHref} class="btn btn-primary mobile-cta">{ctaLabel}</a>
  </div>
</nav>

<style>
  /* ── Header bar ── */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height, 48px);
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 1000;
    display: flex;
    align-items: center;
    transition: box-shadow 0.3s var(--ease, ease);
  }

  .header.scrolled {
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.08);
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* ── Logo ── */
  .logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text, #1D1D1F);
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .logo:hover {
    color: var(--text, #1D1D1F);
  }

  .logo-dot {
    color: var(--accent, #0A84FF);
    margin-left: 1px;
  }

  /* ── Desktop nav ── */
  .nav-desktop {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-list {
    display: flex;
    gap: 1.75rem;
    align-items: center;
  }

  .nav-link {
    font-size: 14px;
    font-weight: 400;
    color: var(--text, #1D1D1F);
    transition: color 0.2s var(--ease, ease);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--accent, #0A84FF);
  }

  .chevron-icon {
    transition: transform 0.2s var(--ease, ease);
  }

  /* ── Dropdown ── */
  .has-dropdown {
    position: relative;
  }

  .dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 200px;
    background: #fff;
    border-radius: var(--radius-sm, 8px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 1px 3px rgba(0, 0, 0, 0.06);
    padding: 0.5rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(8px);
    transition: opacity 0.2s var(--ease, ease), visibility 0.2s, transform 0.2s var(--ease, ease);
    pointer-events: none;
  }

  .has-dropdown:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .has-dropdown:hover .chevron-icon {
    transform: rotate(180deg);
  }

  .dropdown-list {
    display: flex;
    flex-direction: column;
  }

  .dropdown-link {
    display: block;
    padding: 0.5rem 1.25rem;
    font-size: 14px;
    color: var(--text, #1D1D1F);
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .dropdown-link:hover,
  .dropdown-link.active {
    background: var(--bg-alt, #F5F5F7);
    color: var(--accent, #0A84FF);
  }

  /* ── Desktop CTA ── */
  .header-cta {
    padding: 0.5rem 1.25rem;
    font-size: 14px;
    flex-shrink: 0;
  }

  /* ── Hamburger ── */
  .menu-toggle {
    display: none;
    width: 44px;
    height: 44px;
    position: relative;
    flex-shrink: 0;
  }

  .hamburger,
  .hamburger::before,
  .hamburger::after {
    width: 20px;
    height: 1.5px;
    background: var(--text, #1D1D1F);
    border-radius: 2px;
    transition: all 0.3s var(--ease, ease);
    position: absolute;
    left: 12px;
  }

  .hamburger {
    top: 21px;
  }

  .hamburger::before {
    content: '';
    top: -6px;
  }

  .hamburger::after {
    content: '';
    top: 6px;
  }

  .menu-toggle.open .hamburger {
    background: transparent;
  }

  .menu-toggle.open .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }

  .menu-toggle.open .hamburger::after {
    top: 0;
    transform: rotate(-45deg);
  }

  /* ── Mobile overlay ── */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 998;
    opacity: 0;
    transition: opacity 0.3s var(--ease, ease);
  }

  .mobile-overlay.visible {
    display: block;
    opacity: 1;
  }

  /* ── Mobile panel ── */
  .mobile-panel {
    position: fixed;
    top: var(--header-height, 48px);
    right: 0;
    bottom: 0;
    width: 85%;
    max-width: 360px;
    background: var(--bg, #fff);
    z-index: 999;
    transform: translateX(100%);
    transition: transform 0.3s var(--ease, ease);
    display: none;
    flex-direction: column;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mobile-panel.open {
    transform: translateX(0);
  }

  /* Panel header */
  .mobile-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 1.25rem;
    height: 52px;
    background: var(--accent, #0A84FF);
    flex-shrink: 0;
  }

  .mobile-panel-title {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }

  .mobile-close {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    border-radius: 8px;
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    background: transparent;
    cursor: pointer;
    transition: background 0.15s;
  }

  .mobile-close:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  /* Mobile links */
  .mobile-nav-list {
    flex: 1;
    padding: 0.5rem 0;
  }

  .mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    min-height: 48px;
    padding: 0 1.25rem;
    font-size: 1rem;
    font-weight: 400;
    color: var(--text, #1D1D1F);
    transition: background 0.15s;
    text-align: left;
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
  }

  .mobile-link:hover {
    background: var(--bg-alt, #F5F5F7);
  }

  .mobile-link.active {
    color: var(--accent, #0A84FF);
    font-weight: 500;
  }

  .mobile-chevron {
    transition: transform 0.2s var(--ease, ease);
    flex-shrink: 0;
  }

  .mobile-sub-toggle.expanded .mobile-chevron {
    transform: rotate(180deg);
  }

  /* Mobile submenu */
  .mobile-submenu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s var(--ease, ease);
    background: var(--bg-alt, #F5F5F7);
  }

  .mobile-submenu.open {
    max-height: 260px;
  }

  .mobile-sublink {
    padding-left: 2rem;
    font-size: 0.9375rem;
    min-height: 44px;
  }

  /* Panel footer */
  .mobile-panel-footer {
    padding: 1rem 1.25rem;
    border-top: 1px solid var(--border, rgba(0,0,0,0.1));
    flex-shrink: 0;
  }

  .mobile-cta {
    width: 100%;
    justify-content: center;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
  }

  /* ── Mobile breakpoint ── */
  @media (max-width: 768px) {
    .nav-desktop,
    .header-cta {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    .mobile-panel {
      display: flex;
    }
  }

  @media (max-width: 400px) {
    .mobile-panel {
      width: 100%;
      max-width: none;
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var toggle = document.getElementById("menuToggle");
    var panel = document.getElementById("mobilePanel");
    var overlay = document.getElementById("mobileOverlay");
    var closeBtn = document.getElementById("mobileClose");
    var header = document.getElementById("header");

    function openMenu() {
      toggle.classList.add("open");
      toggle.setAttribute("aria-expanded", "true");
      panel.classList.add("open");
      overlay.classList.add("visible");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      toggle.classList.remove("open");
      toggle.setAttribute("aria-expanded", "false");
      panel.classList.remove("open");
      overlay.classList.remove("visible");
      document.body.style.overflow = "";
    }

    if (toggle) {
      toggle.addEventListener("click", function () {
        if (panel.classList.contains("open")) {
          closeMenu();
        } else {
          openMenu();
        }
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener("click", closeMenu);
    }

    if (overlay) {
      overlay.addEventListener("click", closeMenu);
    }

    // Close on link click
    var mobileLinks = panel ? panel.querySelectorAll("a") : [];
    for (var i = 0; i < mobileLinks.length; i++) {
      mobileLinks[i].addEventListener("click", closeMenu);
    }

    // Submenu toggle
    var subToggles = document.querySelectorAll("[data-submenu]");
    for (var j = 0; j < subToggles.length; j++) {
      subToggles[j].addEventListener("click", function () {
        this.classList.toggle("expanded");
        var submenu = this.nextElementSibling;
        if (submenu) {
          submenu.classList.toggle("open");
        }
      });
    }

    // Scroll effect
    var lastScroll = 0;
    window.addEventListener("scroll", function () {
      var scrollY = window.pageYOffset || document.documentElement.scrollTop;
      if (scrollY > 50) {
        header.classList.add("scrolled");
      } else {
        header.classList.remove("scrolled");
      }
      lastScroll = scrollY;
    }, { passive: true });
  });
</script>
