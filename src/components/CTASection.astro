---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "¿Listo para crecer en línea?",
  subtitle = "Cuéntanos tu proyecto. Respuesta en menos de 24 horas."
} = Astro.props;
---

<section class="cta-final">
  <div class="container cta-inner">
    <h2 class="cta-title">{title}</h2>
    <p class="cta-subtitle">{subtitle}</p>
    <div class="cta-actions">
      <a href="/cotizar/" class="btn btn-primary">Iniciar proyecto →</a>
      <a href="mailto:hola@origenlab.mx" class="btn btn-outline-white">hola@origenlab.mx</a>
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: var(--bg-dark);
    padding: var(--section-py) 0;
  }

  .cta-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--text-on-dark);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: var(--text-on-dark-muted);
    margin-bottom: 2.5rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
