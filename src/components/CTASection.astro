---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "¿Listo para tener la web que mereces?",
  subtitle = "Agenda una llamada gratuita y platiquemos sobre tu proyecto. Sin compromisos."
} = Astro.props;
---

<section class="cta-section">
  <div class="container cta-inner">
    <h2 class="cta-title">{title}</h2>
    <p class="cta-subtitle">{subtitle}</p>
    <div class="cta-actions">
      <a href="/cotizar/" class="btn btn-primary">
        Solicitar cotización gratis
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/contacto/" class="btn btn-outline">Contáctanos</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 5rem 0;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(108, 99, 255, 0.05), rgba(0, 212, 255, 0.05));
    pointer-events: none;
  }

  .cta-inner {
    text-align: center;
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 4rem 2rem;
  }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .cta-subtitle {
    font-size: 1.125rem;
    color: var(--color-muted);
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
