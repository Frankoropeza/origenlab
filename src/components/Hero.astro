---

<section class="hero">
  <div class="container hero-inner">

    <!-- COLUMNA IZQUIERDA: headline + CTAs -->
    <div class="hero-left">
      <span class="hero-eyebrow">Agencia Digital · México</span>
      <h1 class="hero-title">Desarrollo web que<br>genera resultados reales.</h1>
      <p class="hero-subtitle">Sitios rápidos, modernos y optimizados para SEO. Diseñados para convertir visitantes en clientes.</p>
      <div class="hero-actions">
        <a href="/cotizar/" class="btn btn-primary">Iniciar proyecto →</a>
        <a href="/portafolio/" class="btn btn-outline">Ver portafolio</a>
      </div>
    </div>

    <!-- COLUMNA DERECHA: imagen hero -->
    <div class="hero-right">
      <div class="hero-img-wrap">
        <img
          src="/img/hero/workspace-4.avif"
          alt="Agencia de desarrollo web OrigenLab — workspace profesional"
          width="600"
          height="338"
          loading="eager"
          decoding="async"
          class="hero-img"
        />
        <div class="hero-img-badge">
          <span class="hero-img-badge__num">+15</span>
          <span class="hero-img-badge__label">proyectos<br>entregados</span>
        </div>
        <div class="hero-img-stat">
          <span>⚡</span>
          <span>Sitios que cargan en &lt;1s</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    padding: clamp(80px, 12vw, 140px) 0 clamp(60px, 8vw, 100px);
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* ── Columna izquierda ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-eyebrow {
    display: inline-block;
    padding: 0.375rem 1rem;
    border: 1px solid var(--accent);
    border-radius: 980px;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 1.75rem;
    letter-spacing: 0.02em;
  }

  .hero-title {
    font-size: clamp(2.2rem, 4.5vw, 60px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: 18px;
    font-weight: 400;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 2.25rem;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Columna derecha — imagen ── */
  .hero-right { position: relative; }

  .hero-img-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,0.25);
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
  }

  .hero-img-badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    background: rgba(10,10,20,0.85);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: white;
  }

  .hero-img-badge__num {
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }

  .hero-img-badge__label {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    line-height: 1.4;
  }

  .hero-img-stat {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(10,10,20,0.85);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero-title { font-size: clamp(2rem, 8vw, 48px); }
  }
</style>
