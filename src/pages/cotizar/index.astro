---
import PageLayout from '../../layouts/PageLayout.astro';

const servicios = [
  "Sitio web corporativo",
  "Tienda en línea",
  "Landing page",
  "Blog o revista digital",
  "Rediseño de sitio existente",
  "Mantenimiento mensual",
  "Otro"
];

const presupuestos = [
  "Menos de $10,000 MXN",
  "$10,000 – $25,000 MXN",
  "$25,000 – $50,000 MXN",
  "$50,000 – $100,000 MXN",
  "Más de $100,000 MXN",
  "Por definir"
];
---

<PageLayout
  title="Cotizar proyecto"
  eyebrow="Cotización"
  description="Solicita una cotización gratuita para tu proyecto web. Te respondemos en menos de 24 horas con una propuesta personalizada."
  subtitle="Completar el formulario toma menos de 3 minutos. A partir de ahí, agendamos una llamada rápida para entender tu proyecto a fondo y preparar una propuesta clara con tiempos, alcances y costos reales — sin letra pequeña."
  keywords="cotizar sitio web México, presupuesto desarrollo web, cotización gratis OrigenLab"
>
  <div class="cotizar-wrapper">
    <div class="cotizar-intro">
      <p>Completa el formulario y te enviamos una propuesta <strong>sin costo</strong> en menos de 24 horas.</p>
    </div>

    <form class="cotizar-form" action="#" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="nombre">Nombre *</label>
          <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
        </div>
        <div class="form-group">
          <label for="empresa">Empresa</label>
          <input type="text" id="empresa" name="empresa" placeholder="Nombre de tu empresa" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required placeholder="tu@correo.com" />
        </div>
        <div class="form-group">
          <label for="telefono">Teléfono / WhatsApp</label>
          <input type="tel" id="telefono" name="telefono" placeholder="+52 55 XXXX XXXX" />
        </div>
      </div>

      <div class="form-group">
        <label for="servicio">¿Qué servicio necesitas? *</label>
        <select id="servicio" name="servicio" required>
          <option value="">Selecciona una opción</option>
          {servicios.map(s => <option value={s}>{s}</option>)}
        </select>
      </div>

      <div class="form-group">
        <label for="presupuesto">Presupuesto aproximado</label>
        <select id="presupuesto" name="presupuesto">
          <option value="">Selecciona un rango</option>
          {presupuestos.map(p => <option value={p}>{p}</option>)}
        </select>
      </div>

      <div class="form-group">
        <label for="descripcion">Cuéntanos sobre tu proyecto *</label>
        <textarea id="descripcion" name="descripcion" rows="6" required
          placeholder="¿Qué quieres lograr? ¿Tienes referencias de diseño? ¿Alguna fecha límite?"></textarea>
      </div>

      <div class="form-group">
        <label for="url">¿Tienes un sitio web actual? (URL)</label>
        <input type="url" id="url" name="url" placeholder="https://tusitio.com" />
      </div>

      <button type="submit" class="btn-cotizar">Solicitar cotización gratuita →</button>

      <p class="form-note">
        🔒 Tu información es confidencial. No hacemos spam.
      </p>
    </form>
  </div>
</PageLayout>

<style>
  .cotizar-wrapper {
    max-width: 760px;
    margin: 0 auto;
  }

  .cotizar-intro {
    text-align: center;
    margin-bottom: 2.5rem;
    color: var(--color-muted);
    font-size: 1.1rem;
  }

  .cotizar-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .form-group textarea {
    resize: vertical;
  }

  .btn-cotizar {
    width: 100%;
    background: var(--color-accent);
    color: white;
    border: none;
    padding: 1rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }

  .btn-cotizar:hover {
    opacity: 0.85;
  }

  .form-note {
    text-align: center;
    color: var(--color-muted);
    font-size: 0.85rem;
    margin-top: 1rem;
  }
</style>
