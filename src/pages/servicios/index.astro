---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

const services = [
  {
    title: "Desarrollo Web Profesional",
    description: "Sitios web rápidos, modernos y escalables con Astro, Next.js y React. Rendimiento óptimo garantizado.",
    href: "/servicios/desarrollo-web/",
    icon: "💻"
  },
  {
    title: "Tiendas en Línea",
    description: "E-commerce completo con pasarelas de pago, inventario y logística. Listo para vender.",
    href: "/servicios/tiendas-en-linea/",
    icon: "🛒"
  },
  {
    title: "Landing Pages de Alta Conversión",
    description: "Páginas diseñadas para convertir. Copy persuasivo y diseño orientado a resultados.",
    href: "/servicios/landing-pages/",
    icon: "🚀"
  },
  {
    title: "SEO y Posicionamiento Web",
    description: "Estrategias de posicionamiento orgánico. Auditoría SEO, optimización on-page y link building.",
    href: "/servicios/seo-posicionamiento/",
    icon: "📈"
  },
  {
    title: "Mantenimiento y Soporte Web",
    description: "Tu sitio siempre actualizado, seguro y funcionando. Actualizaciones, backups y soporte técnico.",
    href: "/servicios/",
    icon: "🔧"
  }
];
---

<PageLayout
  title="Servicios"
  description="Soluciones web completas para impulsar tu negocio en el mundo digital."
  keywords="servicios web, desarrollo web México, diseño web, SEO, tiendas en línea"
>
  <div class="services-grid">
    {services.map((service) => (
      <ServiceCard {...service} />
    ))}
  </div>

  <CTASection />
</PageLayout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2px;
    margin-bottom: 4rem;
  }
</style>
