---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

const services = [
  {
    title: "Desarrollo Web Profesional",
    description: "Sitios web rápidos, modernos y escalables con Astro, Next.js y React. Rendimiento óptimo garantizado.",
    price: "Desde $15,000 MXN",
    href: "/servicios/desarrollo-web/",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>'
  },
  {
    title: "Tiendas en Línea",
    description: "E-commerce completo con Shopify, WooCommerce o soluciones custom. Pasarelas de pago, inventario y logística.",
    price: "Desde $25,000 MXN",
    href: "/servicios/tiendas-en-linea/",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>'
  },
  {
    title: "Landing Pages de Alta Conversión",
    description: "Páginas diseñadas para convertir. A/B testing, copywriting persuasivo y diseño orientado a resultados.",
    price: "Desde $8,000 MXN",
    href: "/servicios/landing-pages/",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>'
  },
  {
    title: "SEO y Posicionamiento Web",
    description: "Estrategias de posicionamiento orgánico. Auditoría SEO, optimización on-page, contenido y link building.",
    price: "Desde $5,000 MXN/mes",
    href: "/servicios/seo-posicionamiento/",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>'
  },
  {
    title: "Mantenimiento y Soporte Web",
    description: "Tu sitio siempre actualizado, seguro y funcionando. Actualizaciones, backups, monitoreo y soporte técnico.",
    price: "Desde $3,000 MXN/mes",
    href: "/servicios/",
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>'
  }
];
---

<PageLayout
  title="Servicios"
  description="Soluciones web completas para impulsar tu negocio en el mundo digital."
  keywords="servicios web, desarrollo web México, diseño web, SEO, tiendas en línea"
>
  <div class="services-grid">
    {services.map((service) => (
      <ServiceCard {...service} />
    ))}
  </div>

  <CTASection />
</PageLayout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }
</style>
