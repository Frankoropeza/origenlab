---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTASection from '../../components/CTASection.astro';

const services = [
  {
    title: "Desarrollo Web",
    description: "Sitios corporativos modernos, rápidos y a medida. Construidos con tecnología de vanguardia para negocios mexicanos.",
    href: "/servicios/desarrollo-web/",
    icon: "💻"
  },
  {
    title: "Tiendas en Línea",
    description: "E-commerce completo con integración de Mercado Pago, OXXO Pay y Stripe. Tu tienda lista para vender.",
    href: "/servicios/tiendas-en-linea/",
    icon: "🛒"
  },
  {
    title: "Landing Pages",
    description: "Páginas de aterrizaje de alta conversión con copy estratégico, velocidad extrema y diseño centrado en resultados.",
    href: "/servicios/landing-pages/",
    icon: "🚀"
  },
  {
    title: "Rediseño Web",
    description: "Transforma tu sitio actual en una plataforma moderna, veloz y alineada con los estándares actuales de diseño.",
    href: "/servicios/rediseno-web/",
    icon: "✦"
  }
];
---

<PageLayout
  title="Servicios"
  eyebrow="Lo que hacemos"
  description="Soluciones web completas para impulsar tu negocio en el mundo digital."
  subtitle="Desde el diseño hasta el posicionamiento, cada servicio que ofrecemos está pensado para resolver un problema real de negocio. No vendemos horas de trabajo — entregamos resultados concretos con tecnología de vanguardia y un proceso transparente de principio a fin."
  keywords="servicios web, desarrollo web México, diseño web, SEO, tiendas en línea"
>
  <div class="services-grid">
    {services.map((service) => (
      <ServiceCard {...service} />
    ))}
  </div>

  <CTASection />
</PageLayout>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin: 3rem 0 4rem;
    padding: 0 1.5rem;
  }
  @media (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
