---

<BaseLayout
  title="Directorio de Empresas CDMX y EdoMex — OrigenLab"
  description="Directorio de negocios locales en Ciudad de México y Estado de México. Empresas verificadas en Google Maps. Si tu negocio aparece aquí y quieres tu propio sitio web, contáctanos."
  keywords="directorio empresas CDMX, negocios Ciudad de México, directorio Estado de México, empresas sin sitio web CDMX, negocios locales México"
>

  <!-- HERO -->
  <section class="dir-hero">
    <div class="container">
      <div class="dir-hero__content">
        <span class="eyebrow">Directorio Local</span>
        <h1 class="dir-hero__title">Negocios de CDMX y EdoMex<br />que merecen estar en línea.</h1>
        <p class="dir-hero__sub">Encontramos negocios locales con presencia en Google Maps que aún no tienen sitio web. Si tu empresa aparece aquí, podemos ayudarte a crear tu presencia digital profesional.</p>
      </div>
      <div class="dir-hero__stats">
        <div class="stat">
          <span class="stat__num">{empresas.length}</span>
          <span class="stat__label">Negocios listados</span>
        </div>
        <div class="stat">
          <span class="stat__num">2</span>
          <span class="stat__label">Estados cubiertos</span>
        </div>
        <div class="stat">
          <span class="stat__num">{categorias.length - 1}</span>
          <span class="stat__label">Giros comerciales</span>
        </div>
      </div>
    </div>
  </section>

  <!-- DIRECTORIO -->
  <section class="dir-main">
    <div class="container">

      <!-- Filtros por categoría -->
      <div class="dir-filters" id="filtros">
        {categorias.map(cat => (
          <button class:list={["filter-btn", { active: cat === "Todas" }]} data-filter={cat}>
            {cat}
          </button>
        ))}
      </div>

      <!-- Grid de empresas -->
      <div class="dir-grid" id="dirGrid">
        {empresas.map(e => (
          <div class="dir-item" data-giro={e.giro}>
            <DirectoryCard {...e} />
          </div>
        ))}
      </div>

      <!-- CTA intermedio -->
      <div class="dir-cta-box">
        <div class="dir-cta-box__content">
          <h2 class="dir-cta-box__title">¿Tu negocio no aparece pero tampoco tienes sitio web?</h2>
          <p class="dir-cta-box__text">Cuéntanos de tu empresa y te enviamos una propuesta sin costo. La mayoría de nuestros proyectos están listos en 2 a 4 semanas.</p>
        </div>
        <a href="/cotizar/?ref=directorio" class="btn btn-primary">Quiero mi sitio web →</a>
      </div>

    </div>
  </section>

  <CTASection />

</BaseLayout>

<style>
  /* --- HERO --- */
  .dir-hero {
    background: var(--bg-alt);
    padding: calc(var(--header-height) + 4rem) 0 4rem;
    border-bottom: 1px solid var(--border);
  }

  .dir-hero__content {
    max-width: 720px;
    margin-bottom: 3rem;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.3rem 0.875rem;
    border: 1px solid var(--accent);
    border-radius: 980px;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .dir-hero__title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text);
    margin: 0 0 1.25rem;
  }

  .dir-hero__sub {
    font-size: 17px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 600px;
    margin: 0;
  }

  .dir-hero__stats {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat__num {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat__label {
    font-size: 13px;
    color: var(--text-muted);
  }

  /* --- MAIN --- */
  .dir-main {
    padding: 4rem 0 5rem;
    background: var(--bg);
  }

  /* --- FILTROS --- */
  .dir-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    font-size: 13px;
    font-weight: 500;
    padding: 0.4rem 1rem;
    border-radius: 980px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover,
  .filter-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(99, 102, 241, 0.06);
  }

  /* --- GRID --- */
  .dir-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .dir-item {
    transition: opacity 0.2s;
  }

  .dir-item.hidden {
    display: none;
  }

  /* --- CTA BOX --- */
  .dir-cta-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2.5rem 3rem;
    flex-wrap: wrap;
  }

  .dir-cta-box__content {
    max-width: 600px;
  }

  .dir-cta-box__title {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .dir-cta-box__text {
    font-size: 15px;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 1200px) {
    .dir-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 900px) {
    .dir-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .dir-hero {
      padding-top: calc(var(--header-height) + 2.5rem);
    }

    .dir-hero__stats {
      gap: 2rem;
    }

    .dir-grid {
      grid-template-columns: 1fr;
    }

    .dir-cta-box {
      padding: 2rem;
    }
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.dir-item');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      items.forEach(item => {
        if (filter === 'Todas' || item.dataset.giro === filter) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      });
    });
  });
</script>
