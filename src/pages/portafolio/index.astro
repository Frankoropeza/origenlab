---
import PageLayout from '../../layouts/PageLayout.astro';

const proyectos = [
  {
    nombre: "CADECA",
    categoria: "Sitio Corporativo B2B",
    descripcion: "Sitio web completo para fabricante de cajas de cartón en CDMX. 127 páginas, catálogo de 30+ SKUs, zonas de cobertura y cotizador integrado. Optimizado para búsquedas locales en CDMX y Estado de México.",
    tags: ["Astro", "B2B", "SEO Local", "Catálogo"],
    color: "#E05800",
    img: "/img/portafolio/cadeca-1.avif",
    url: "https://cajas-de-carton.com",
    resultado: "127 páginas indexadas"
  },
  {
    nombre: "REDEIL",
    categoria: "Sitio de Servicios + Cotizador",
    descripcion: "Rediseño web para empresa líder en renta de iluminación para eventos en CDMX. Catálogo de equipos, galería de eventos y formulario de cotización. Incremento real en solicitudes desde el lanzamiento.",
    tags: ["Astro", "Servicios", "Cotizador", "SEO"],
    color: "#7C3AED",
    img: "/img/portafolio/redeil-2.avif",
    url: "https://rentadeiluminacion.com",
    resultado: "+contactos desde semana 1"
  },
  {
    nombre: "BRINCOLINS",
    categoria: "Directorio + Reservas",
    descripcion: "Directorio web de renta de inflables para fiestas infantiles en CDMX y Estado de México. 14 inflables con páginas individuales, cotizador y directorio de proveedores locales con SEO geolocalizado.",
    tags: ["Astro", "Directorio", "SEO Local", "Entretenimiento"],
    color: "#F59E0B",
    img: "/img/portafolio/brincolins-1.avif",
    url: "https://brincolins.com",
    resultado: "SEO local CDMX + EdoMex"
  },
  {
    nombre: "Gama de México",
    categoria: "Sitio Corporativo",
    descripcion: "Sitio corporativo para empresa establecida en México. Rediseño completo con enfoque en transmitir experiencia, confianza y captura de leads B2B.",
    tags: ["Desarrollo Web", "Corporativo", "B2B"],
    color: "#0EA5E9",
    img: null,
    url: null,
    resultado: "Presencia digital profesional"
  },
  {
    nombre: "Eventech",
    categoria: "Catálogo de Servicios",
    descripcion: "Sitio web para empresa de renta de equipo para eventos. Catálogo completo de productos, galería de eventos realizados y sistema de cotización por WhatsApp.",
    tags: ["Astro", "Catálogo", "Eventos"],
    color: "#10B981",
    img: null,
    url: "https://eventech.mx",
    resultado: "Catálogo digital completo"
  },
  {
    nombre: "Tu Empresa",
    categoria: "Próximo Proyecto",
    descripcion: "¿Tu negocio necesita presencia digital profesional? Diseñamos sitios rápidos, modernos y enfocados en resultados reales. Cotización sin costo en menos de 24 horas.",
    tags: ["Diseño Web", "Desarrollo", "SEO"],
    color: "#6366F1",
    img: null,
    url: "/cotizar/",
    resultado: "¿Empezamos?"
  }
];
---

<PageLayout
  title="Portafolio"
  eyebrow="Nuestro trabajo"
  description="Proyectos reales que hemos construido. Sitios web, tiendas en línea y landing pages con resultados medibles."
  subtitle="Cada proyecto aquí tiene una historia: un negocio con un problema que resolver, un objetivo de crecimiento o una plataforma que necesitaba ser reemplazada. Estos son los trabajos que mejor representan cómo trabajamos y lo que somos capaces de entregar."
  keywords="portafolio desarrollo web México, proyectos web, casos de éxito OrigenLab"
>
  <div class="portfolio-intro">
    <p>Cada proyecto aquí tiene un objetivo: generar resultados. Sitios rápidos, bien diseñados y centrados en conversión.</p>
  </div>

  <div class="projects-grid">
    {proyectos.map(p => (
      <article class="project-card">
        <div class="project-thumb" style={`--accent: ${p.color}`}>
          {p.img ? (
            <img src={p.img} alt={`Proyecto ${p.nombre} — OrigenLab`} width="600" height="338" loading="lazy" class="project-img" />
          ) : (
            <div class="project-initial">{p.nombre[0]}</div>
          )}
          <span class="project-resultado">{p.resultado}</span>
        </div>
        <div class="project-info">
          <span class="project-cat">{p.categoria}</span>
          <h3>{p.nombre}</h3>
          <p>{p.descripcion}</p>
          <div class="project-tags">
            {p.tags.map(t => <span class="tag">{t}</span>)}
          </div>
          {p.url && (
            <a href={p.url} class="project-link" target={p.url.startsWith('http') ? '_blank' : '_self'} rel={p.url.startsWith('http') ? 'noopener noreferrer' : ''}>
              {p.url.startsWith('http') ? 'Ver sitio →' : 'Cotizar proyecto →'}
            </a>
          )}
        </div>
      </article>
    ))}
  </div>

  <div class="portfolio-cta">
    <h2>¿Quieres un proyecto así?</h2>
    <p>Platícanos tu idea y construyamos algo juntos.</p>
    <a href="/cotizar" class="btn-primary">Solicitar cotización</a>
  </div>
</PageLayout>

<style>
  .portfolio-intro {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
    color: var(--color-muted);
    font-size: 1.1rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s, border-color 0.3s;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
  }

  .project-thumb {
    height: 200px;
    background: color-mix(in srgb, var(--accent) 15%, var(--color-surface));
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .project-card:hover .project-img { transform: scale(1.04); }

  .project-resultado {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(8px);
    color: var(--accent, #0ea5e9);
    font-size: 11px;
    font-weight: 700;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .project-initial {
    font-size: 4rem;
    font-weight: 900;
    color: var(--accent, var(--color-accent));
    opacity: 0.4;
    font-family: var(--font-mono);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: 0.75rem;
    transition: gap 0.2s;
  }
  .project-link:hover { gap: 0.5rem; }

  .project-info {
    padding: 1.5rem;
  }

  .project-cat {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.5rem;
  }

  .project-info h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .project-info p {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .portfolio-cta {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--color-surface);
    border-radius: 16px;
    border: 1px solid var(--color-border);
  }

  .portfolio-cta h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .portfolio-cta p {
    color: var(--color-muted);
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.85;
  }
</style>
