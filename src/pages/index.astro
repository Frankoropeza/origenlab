---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';

const servicios = [
  {
    title: "Desarrollo Web",
    description: "Sitios corporativos modernos, rápidos y optimizados para SEO. Construidos con Astro y las mejores prácticas.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    price: "Desde $15,000 MXN",
    href: "/servicios/desarrollo-web/"
  },
  {
    title: "Tiendas en Línea",
    description: "E-commerce completo con carrito, pagos y gestión de inventario. Integración con Mercado Pago y Stripe.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>`,
    price: "Desde $20,000 MXN",
    href: "/servicios/tiendas-en-linea/"
  },
  {
    title: "Landing Pages",
    description: "Páginas de aterrizaje de alta conversión. Diseño persuasivo + copy estratégico + velocidad extrema.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    price: "Desde $8,500 MXN",
    href: "/servicios/landing-pages/"
  },
  {
    title: "SEO y Posicionamiento",
    description: "Aparece en los primeros resultados de Google. SEO técnico, on-page y local para empresas mexicanas.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
    price: "Desde $4,500 MXN/mes",
    href: "/servicios/seo-posicionamiento/"
  }
];

const testimonios = [
  {
    name: "Carlos Mendoza",
    company: "CADECA México",
    text: "OrigenLab transformó nuestra presencia digital. El sitio carga increíblemente rápido y nuestras cotizaciones en línea aumentaron un 60% en el primer mes.",
    role: "Director Comercial"
  },
  {
    name: "Sofía Ramírez",
    company: "TiendaFlex MX",
    text: "Excelente trabajo en nuestra tienda en línea. El proceso fue claro desde el inicio y entregaron antes del plazo acordado. 100% recomendados.",
    role: "Fundadora"
  },
  {
    name: "Diego Torres",
    company: "LogiTrack MX",
    text: "Profesionales, creativos y muy responsables. El diseño superó nuestras expectativas y el SEO empezó a dar resultados desde la primera semana.",
    role: "CEO"
  }
];

const faqs = [
  {
    pregunta: "¿Cuánto tiempo toma desarrollar un sitio web?",
    respuesta: "Depende del proyecto: una landing page toma 5–7 días, un sitio corporativo 3–4 semanas, y una tienda en línea 4–6 semanas. Siempre acordamos tiempos antes de comenzar."
  },
  {
    pregunta: "¿Trabajan con empresas de toda la República?",
    respuesta: "Sí. Aunque estamos basados en CDMX, trabajamos con clientes de todo México de forma 100% remota sin ningún problema."
  },
  {
    pregunta: "¿El sitio incluye dominio y hosting?",
    respuesta: "Entregamos el sitio listo para publicar. Te asesoramos con las mejores opciones de dominio y hosting según tu presupuesto, o lo configuramos directamente si lo prefieres."
  },
  {
    pregunta: "¿Puedo actualizar el contenido yo mismo?",
    respuesta: "Sí. Configuramos un panel de administración sencillo o te capacitamos para editar el contenido básico sin necesidad de saber programar."
  },
  {
    pregunta: "¿Ofrecen mantenimiento después de la entrega?",
    respuesta: "Sí, tenemos planes de mantenimiento mensual que incluyen actualizaciones, backups, monitoreo y soporte prioritario."
  }
];
---

<BaseLayout
  title="OrigenLab"
  description="Agencia de desarrollo web profesional en México. Sitios rápidos, modernos y optimizados para SEO que generan resultados reales para tu negocio."
  keywords="desarrollo web México, agencia web CDMX, diseño web profesional, sitios web rápidos, SEO México, tiendas en línea"
>
  <!-- HERO -->
  <Hero />

  <!-- SERVICIOS -->
  <section class="section" id="servicios">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Servicios</span>
        <h2 class="section-title">Todo lo que necesita tu negocio en línea</h2>
        <p class="section-subtitle">Desde el diseño hasta el posicionamiento, manejamos cada parte de tu presencia digital.</p>
      </div>
      <div class="services-grid">
        {servicios.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- POR QUÉ ELEGIRNOS -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Diferencia</span>
        <h2 class="section-title">¿Por qué OrigenLab?</h2>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-number">01</div>
          <h3>Velocidad real</h3>
          <p>Nuestros sitios cargan en menos de 1 segundo. No es marketing — es ingeniería. Usamos Astro, el framework más rápido del mercado.</p>
        </div>
        <div class="why-card">
          <div class="why-number">02</div>
          <h3>SEO desde el código</h3>
          <p>No agregamos SEO al final. Lo construimos desde cero: estructura semántica, Core Web Vitals en verde y schema.org completo.</p>
        </div>
        <div class="why-card">
          <div class="why-number">03</div>
          <h3>Diseño que convierte</h3>
          <p>Cada elemento tiene un propósito: llevar al visitante a la acción. No solo hacemos sitios bonitos, hacemos sitios que venden.</p>
        </div>
        <div class="why-card">
          <div class="why-number">04</div>
          <h3>Comunicación directa</h3>
          <p>Sin intermediarios. Hablas directo con quien construye tu sitio. Actualizaciones diarias y transparencia total en cada etapa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Proceso</span>
        <h2 class="section-title">Cómo trabajamos</h2>
        <p class="section-subtitle">Simple, transparente y sin sorpresas.</p>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-circle">1</div>
          <div class="step-line"></div>
          <h3>Descubrimiento</h3>
          <p>Entendemos tu negocio, objetivos y competencia. Definimos el alcance y te damos un presupuesto claro.</p>
        </div>
        <div class="process-step">
          <div class="step-circle">2</div>
          <div class="step-line"></div>
          <h3>Diseño</h3>
          <p>Creamos el diseño visual. Tú lo revisas, apruebas y ajustamos hasta que quede perfecto.</p>
        </div>
        <div class="process-step">
          <div class="step-circle">3</div>
          <div class="step-line"></div>
          <h3>Desarrollo</h3>
          <p>Construimos el sitio con código limpio, rápido y escalable. Pruebas en todos los dispositivos.</p>
        </div>
        <div class="process-step">
          <div class="step-circle">4</div>
          <h3>Lanzamiento</h3>
          <p>Publicamos, configuramos analítica y te entregamos todo listo para crecer.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Testimonios</span>
        <h2 class="section-title">Lo que dicen nuestros clientes</h2>
      </div>
      <div class="testimonials-grid">
        {testimonios.map(t => <TestimonialCard {...t} />)}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">FAQ</span>
        <h2 class="section-title">Preguntas frecuentes</h2>
      </div>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary>{f.pregunta}</summary>
            <p>{f.respuesta}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <CTASection />
</BaseLayout>

<style>
  .section {
    padding: 6rem 0;
  }

  .section-alt {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Servicios */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  /* Por qué */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }

  .why-card {
    padding: 2rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: border-color 0.3s;
  }

  .why-card:hover {
    border-color: var(--color-accent);
  }

  .why-number {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-accent);
    opacity: 0.2;
    font-family: var(--font-mono);
    margin-bottom: 1rem;
  }

  .why-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .why-card p {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* Proceso */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    position: relative;
  }

  .process-step {
    text-align: center;
  }

  .step-circle {
    width: 56px;
    height: 56px;
    background: var(--color-accent);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 800;
    margin: 0 auto 1.25rem;
  }

  .process-step h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .process-step p {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Testimonios */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* FAQ */
  .faq-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item[open] {
    border-color: var(--color-accent);
  }

  .faq-item summary {
    padding: 1.25rem 1.5rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.5rem;
    color: var(--color-accent);
    transition: transform 0.2s;
    line-height: 1;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    padding: 0 1.5rem 1.25rem;
    color: var(--color-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }
</style>
