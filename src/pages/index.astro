---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';

const servicios = [
  {
    title: "Desarrollo Web",
    description: "Sitios corporativos rápidos, modernos y optimizados para SEO. Construidos con tecnología de vanguardia.",
    icon: "💻",
    href: "/servicios/desarrollo-web/"
  },
  {
    title: "Tiendas en Línea",
    description: "E-commerce completo con integración de Mercado Pago y Stripe. Tu tienda lista para vender.",
    icon: "🛒",
    href: "/servicios/tiendas-en-linea/"
  },
  {
    title: "Landing Pages",
    description: "Páginas de aterrizaje de alta conversión con copy estratégico y velocidad extrema.",
    icon: "🚀",
    href: "/servicios/landing-pages/"
  },
  {
    title: "SEO y Posicionamiento",
    description: "Aparece en los primeros resultados de Google. SEO técnico y local para empresas en México.",
    icon: "📈",
    href: "/servicios/seo-posicionamiento/"
  }
];

const testimonios = [
  {
    name: "Carlos Mendoza",
    company: "Restaurante La Capital",
    text: "Desde que lanzamos el nuevo sitio, nuestras reservaciones en línea se triplicaron. El diseño es elegante y la velocidad impresionante.",
    role: "Propietario"
  },
  {
    name: "Sofía Ramírez",
    company: "Despacho Ramírez & Asociados",
    text: "Profesionales y puntuales. Nos entregaron un sitio que transmite exactamente la seriedad y confianza que necesitábamos.",
    role: "Socia fundadora"
  },
  {
    name: "Diego Torres",
    company: "TiendaMX",
    text: "Nuestra tienda en línea genera más ventas que la tienda física. La integración con Mercado Pago fue impecable.",
    role: "Director General"
  },
  {
    name: "Ana García",
    company: "Estudio Creativo Mija",
    text: "El portafolio que nos diseñaron es una obra de arte. Cada proyecto se presenta de forma espectacular y hemos conseguido clientes internacionales.",
    role: "Directora Creativa"
  },
  {
    name: "Roberto Sánchez",
    company: "Clínica Dental Sonríe",
    text: "Aparecemos en primer lugar en Google cuando buscan dentistas en nuestra zona. La inversión se pagó sola en dos meses.",
    role: "Director Médico"
  },
  {
    name: "María López",
    company: "Constructora Horizonte",
    text: "El sitio que nos hicieron refleja perfectamente la calidad de nuestros proyectos. Los clientes nos contactan más y con mayor confianza.",
    role: "Gerente Comercial"
  }
];

const porqueElegirnos = [
  {
    num: "#01",
    title: "Velocidad extrema",
    desc: "Sitios que cargan en menos de 1 segundo. Rendimiento real, no promesas."
  },
  {
    num: "#02",
    title: "SEO desde el código",
    desc: "Arquitectura técnica optimizada. Estructura semántica y Core Web Vitals en verde."
  },
  {
    num: "#03",
    title: "Diseño que convierte",
    desc: "UX/UI centrado en resultados. Cada elemento tiene un propósito: convertir."
  },
  {
    num: "#04",
    title: "Soporte continuo",
    desc: "Acompañamiento post-lanzamiento. No desaparecemos después de entregar."
  },
  {
    num: "#05",
    title: "Tecnología moderna",
    desc: "Astro, Next.js y las mejores herramientas del mercado para tu proyecto."
  },
  {
    num: "#06",
    title: "Resultados medibles",
    desc: "Reportes mensuales de métricas. Sabrás exactamente cómo rinde tu sitio."
  }
];
---

<BaseLayout
  title="OrigenLab"
  description="Agencia de desarrollo web profesional en México. Sitios rápidos, modernos y optimizados para SEO que generan resultados reales para tu negocio."
  keywords="desarrollo web México, agencia web CDMX, diseño web profesional, sitios web rápidos, SEO México, tiendas en línea"
>
  <!-- SECCIÓN 1: HERO -->
  <Hero />

  <!-- SECCIÓN 2: BARRA CTA -->
  <section class="cta-bar">
    <div class="container cta-bar__inner">
      <div class="cta-bar__text">
        <p class="cta-bar__headline">¿Tienes un proyecto en mente?</p>
        <p class="cta-bar__sub">Cuéntanos tu idea — respondemos en menos de 24 horas con una propuesta personalizada.</p>
      </div>
      <div class="cta-bar__actions">
        <a href="/cotizar/" class="btn btn-primary">Iniciar proyecto →</a>
        <a href="mailto:hola@origenlab.mx" class="cta-bar__link">hola@origenlab.mx</a>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 3: SERVICIOS -->
  <section class="services-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Servicios</span>
        <h2 class="section-title">Todo lo que tu negocio necesita en línea.</h2>
        <p class="section-subtitle">Desde el diseño hasta el posicionamiento, construimos cada parte de tu presencia digital.</p>
      </div>
      <div class="services-grid">
        {servicios.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 4: POR QUÉ ELEGIRNOS -->
  <section class="why-section">
    <div class="container">
      <div class="section-header-dark">
        <span class="eyebrow-dark">Diferencia</span>
        <h2 class="section-title-dark">¿Por qué OrigenLab?</h2>
      </div>
      <div class="why-grid">
        {porqueElegirnos.map(item => (
          <div class="why-card">
            <span class="why-number">{item.num}</span>
            <h3 class="why-title">{item.title}</h3>
            <p class="why-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 5: PROCESO -->
  <section class="process-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Cómo trabajamos</h2>
        <p class="section-subtitle">Simple, transparente y sin sorpresas.</p>
      </div>
      <div class="process-grid">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-connector"></div>
          <h3 class="step-title">Descubrimiento</h3>
          <p class="step-desc">Entendemos tu negocio, objetivos y competencia.</p>
        </div>
        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-connector"></div>
          <h3 class="step-title">Diseño</h3>
          <p class="step-desc">Prototipo y aprobación visual antes de desarrollar.</p>
        </div>
        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-connector"></div>
          <h3 class="step-title">Desarrollo</h3>
          <p class="step-desc">Código limpio, optimizado y listo para escalar.</p>
        </div>
        <div class="process-step">
          <div class="step-number">4</div>
          <h3 class="step-title">Lanzamiento</h3>
          <p class="step-desc">Deploy, SEO técnico y capacitación completa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 6: TESTIMONIOS -->
  <section class="testimonials-section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Testimonios</span>
        <h2 class="section-title">Lo que dicen nuestros clientes.</h2>
      </div>
      <div class="testimonials-grid">
        {testimonios.map(t => <TestimonialCard {...t} />)}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 7: CTA FINAL -->
  <CTASection />
</BaseLayout>

<style>
  /* --- Utilidades de sección --- */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.3rem 0.875rem;
    border: 1px solid var(--accent);
    border-radius: 980px;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 21px;
    font-weight: 400;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* --- SECCIÓN 2: CTA BAR --- */
  .cta-bar {
    background: var(--text);
    padding: 2.5rem 0;
  }

  .cta-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-bar__text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cta-bar__headline {
    font-size: 22px;
    font-weight: 600;
    color: #FFFFFF;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .cta-bar__sub {
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }

  .cta-bar__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .cta-bar__link {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .cta-bar__link:hover {
    color: #FFFFFF;
  }

  /* --- SECCIÓN 3: SERVICIOS --- */
  .services-section {
    background: var(--bg);
    padding: var(--section-py) 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-cards);
  }

  /* --- SECCIÓN 4: POR QUÉ ELEGIRNOS --- */
  .why-section {
    background: var(--bg-dark);
    padding: var(--section-py) 0;
  }

  .section-header-dark {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .eyebrow-dark {
    display: inline-block;
    padding: 0.3rem 0.875rem;
    border: 1px solid var(--accent);
    border-radius: 980px;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .section-title-dark {
    font-size: clamp(2rem, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-on-dark);
    line-height: 1.1;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-cards);
  }

  .why-card {
    background: #1C1C1E;
    border-radius: 20px;
    padding: 40px;
  }

  .why-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    display: block;
    margin-bottom: 1rem;
  }

  .why-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-on-dark);
    margin-bottom: 0.75rem;
  }

  .why-desc {
    font-size: 15px;
    color: var(--text-on-dark-muted);
    line-height: 1.6;
  }

  /* --- SECCIÓN 5: PROCESO --- */
  .process-section {
    background: var(--bg-alt);
    padding: var(--section-py) 0;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .process-step {
    position: relative;
  }

  .step-number {
    width: 48px;
    height: 48px;
    background: var(--accent);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 auto 1.25rem;
    position: relative;
    z-index: 1;
  }

  .step-connector {
    position: absolute;
    top: 24px;
    left: calc(50% + 24px);
    right: calc(-50% + 24px);
    height: 2px;
    background: var(--accent);
    opacity: 0.3;
  }

  .process-step:last-child .step-connector {
    display: none;
  }

  .step-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* --- SECCIÓN 6: TESTIMONIOS --- */
  .testimonials-section {
    background: var(--bg);
    padding: var(--section-py) 0;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 1024px) {
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cta-bar__inner {
      flex-direction: column;
      text-align: center;
    }
    .cta-bar__actions {
      justify-content: center;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .process-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .step-connector {
      display: none;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .section-subtitle {
      font-size: 17px;
    }
  }
</style>
