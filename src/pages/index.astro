---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';

const servicios = [
  {
    title: "Desarrollo Web",
    description: "Sitios corporativos modernos, rápidos y a medida. Construidos con tecnología de vanguardia para negocios mexicanos.",
    icon: "💻",
    href: "/servicios/desarrollo-web/"
  },
  {
    title: "Tiendas en Línea",
    description: "E-commerce completo con integración de Mercado Pago, OXXO Pay y Stripe. Tu tienda lista para vender.",
    icon: "🛒",
    href: "/servicios/tiendas-en-linea/"
  },
  {
    title: "Landing Pages",
    description: "Páginas de aterrizaje de alta conversión con copy estratégico, velocidad extrema y diseño centrado en resultados.",
    icon: "🚀",
    href: "/servicios/landing-pages/"
  },
  {
    title: "Rediseño Web",
    description: "Transforma tu sitio actual en una plataforma moderna, veloz y alineada con los estándares actuales de diseño.",
    icon: "✦",
    href: "/servicios/rediseno-web/"
  }
];

const testimonios = [
  {
    name: "Equipo REDEIL",
    company: "REDEIL",
    text: "OrigenLab transformó nuestra presencia digital por completo. El nuevo sitio refleja el nivel profesional de nuestros servicios de iluminación para eventos y hemos notado un incremento real en solicitudes de cotización desde que lo lanzamos.",
    role: "Renta de Iluminación Profesional",
    url: "https://rentadeiluminacion.com/"
  },
  {
    name: "REDEIL CDMX",
    company: "REDEIL",
    text: "El proceso fue muy claro desde el inicio: nos explicaron cada etapa, cumplieron los tiempos y el resultado superó nuestras expectativas. Ahora nuestros clientes encuentran fácilmente todo lo que ofrecemos y el sitio transmite la calidad de nuestro equipo.",
    role: "Renta de Iluminación para Eventos",
    url: "https://rentadeiluminacion.com/"
  },
  {
    name: "Equipo Eventech",
    company: "Eventech",
    text: "Necesitábamos un sitio que mostrara todo nuestro catálogo de renta de equipo para eventos de forma clara y profesional. OrigenLab lo logró: el sitio es rápido, fácil de navegar y nuestros clientes encuentran exactamente lo que buscan.",
    role: "Renta de Equipo para Eventos",
    url: "https://eventech.mx/"
  },
  {
    name: "Ana García",
    company: "Estudio Creativo Mija",
    text: "El portafolio que nos diseñaron es una obra de arte. Cada proyecto se presenta de forma espectacular y hemos conseguido clientes internacionales.",
    role: "Directora Creativa"
  },
  {
    name: "Roberto Sánchez",
    company: "Clínica Dental Sonríe",
    text: "Aparecemos en primer lugar en Google cuando buscan dentistas en nuestra zona. La inversión se pagó sola en dos meses.",
    role: "Director Médico"
  },
  {
    name: "María López",
    company: "Constructora Horizonte",
    text: "El sitio que nos hicieron refleja perfectamente la calidad de nuestros proyectos. Los clientes nos contactan más y con mayor confianza.",
    role: "Gerente Comercial"
  }
];

const proceso = [
  { title: "Descubrimiento", description: "Entendemos tu negocio, objetivos y competencia antes de escribir una sola línea de código.", icon: "", href: "/cotizar/" },
  { title: "Diseño",         description: "Prototipo y aprobación visual completa antes de desarrollar. Tú apruebas antes de avanzar.",  icon: "", href: "/cotizar/" },
  { title: "Desarrollo",     description: "Código limpio, optimizado y listo para escalar. Construido con tecnología de vanguardia.",    icon: "", href: "/cotizar/" },
  { title: "Lanzamiento",    description: "Deploy profesional, capacitación completa y acompañamiento en las primeras semanas.",         icon: "", href: "/cotizar/" },
];

const porqueElegirnos = [
  { title: "Velocidad extrema",    description: "Sitios que cargan en menos de 1 segundo. Rendimiento real, no promesas.",                          icon: "", href: "/servicios/" },
  { title: "Diseño que convierte", description: "UX/UI centrado en resultados. Cada elemento tiene un propósito: convertir visitantes en clientes.", icon: "", href: "/servicios/" },
  { title: "Soporte continuo",     description: "Acompañamiento post-lanzamiento. No desaparecemos después de entregar tu proyecto.",               icon: "", href: "/nosotros/"  },
  { title: "Tecnología moderna",   description: "Astro, Next.js y las mejores herramientas del mercado. Tu sitio listo para escalar.",              icon: "", href: "/servicios/" },
];
---

<BaseLayout
  title="OrigenLab"
  description="Agencia de desarrollo web profesional en México. Sitios rápidos, modernos y optimizados para SEO que generan resultados reales para tu negocio."
  keywords="desarrollo web México, agencia web CDMX, diseño web profesional, sitios web rápidos, SEO México, tiendas en línea"
>
  <!-- SECCIÓN 1: HERO -->
  <Hero />

  <!-- SECCIÓN 2: BARRA CTA -->
  <section class="cta-bar">
    <div class="container cta-bar__inner">
      <div class="cta-bar__text">
        <p class="cta-bar__headline">¿Tienes un proyecto en mente?</p>
        <p class="cta-bar__sub">Cuéntanos tu idea — respondemos en menos de 24 horas con una propuesta personalizada.</p>
      </div>
      <div class="cta-bar__actions">
        <a href="/cotizar/" class="btn btn-primary">Iniciar proyecto →</a>
        <a href="mailto:hola@origenlab.mx" class="cta-bar__link">hola@origenlab.mx</a>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 3: SERVICIOS -->
  <section class="services-section">
    <div class="container">
      <div class="sh">
        <div class="sh__left">
          <span class="eyebrow">Servicios</span>
          <h2 class="section-title">Todo lo que tu negocio necesita en línea.</h2>
          <p class="section-subtitle">Desde el diseño hasta el posicionamiento, construimos cada parte de tu presencia digital.</p>
        </div>
        <div class="sh__right">
          <p class="sh__copy">Cada servicio que ofrecemos en OrigenLab está diseñado para resolver un problema real de negocio. No vendemos tecnología por sí misma — construimos sitios web que trabajan por ti: rápidos, bien diseñados, fáciles de administrar y listos para escalar con tu empresa. Nuestros proyectos integran diseño UX, código de producción limpio y arquitectura sólida en un solo flujo de trabajo eficiente y transparente.</p>
          <p class="sh__copy">Desde sitios corporativos hasta tiendas en línea con integración a Mercado Pago, OXXO Pay y Stripe, pasando por landing pages de alta conversión y rediseños completos de plataformas existentes — todo bajo un mismo equipo que conoce tu proyecto de principio a fin. Sin subcontrataciones, sin intermediarios, sin sorpresas.</p>
        </div>
      </div>
      <div class="services-grid">
        {servicios.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 4: POR QUÉ ELEGIRNOS -->
  <section class="why-section">
    <div class="container">
      <div class="sh sh--dark">
        <div class="sh__left">
          <span class="eyebrow-dark">Diferencia</span>
          <h2 class="section-title-dark">¿Por qué OrigenLab?</h2>
        </div>
        <div class="sh__right">
          <p class="sh__copy sh__copy--dark">En un mercado saturado de agencias que prometen lo mismo, OrigenLab se diferencia por una razón simple: entregamos. Cada proyecto tiene un responsable técnico que lo conoce de principio a fin, un proceso de revisión con el cliente en cada etapa y métricas reales de resultado al mes de lanzar. No cobramos por mantenimiento sin sentido ni vendemos paquetes inflados — solo el trabajo necesario para alcanzar tus objetivos.</p>
          <p class="sh__copy sh__copy--dark">Nuestro equipo trabaja exclusivamente con tecnologías modernas de alto rendimiento: Astro, Next.js y arquitecturas estáticas que garantizan velocidades de carga en el primer percentil de Google. Esto no es un diferencial cosmético — la velocidad es un factor de posicionamiento SEO y tiene impacto directo en tu tasa de conversión. Un segundo más de carga puede costarte el 7% de tus ventas.</p>
        </div>
      </div>
      <div class="why-grid">
        {porqueElegirnos.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 5: PROCESO -->
  <section class="process-section">
    <div class="container">
      <div class="sh">
        <div class="sh__left">
          <span class="eyebrow">Proceso</span>
          <h2 class="section-title">Cómo trabajamos</h2>
          <p class="section-subtitle">Simple, transparente y sin sorpresas.</p>
        </div>
        <div class="sh__right">
          <p class="sh__copy">Nuestro proceso de 4 etapas está diseñado para eliminar la incertidumbre que suele rodear a los proyectos digitales. Antes de escribir una sola línea de código, dedicamos tiempo a entender tu mercado, analizar a tu competencia en Google y definir con precisión qué necesita tu sitio para convertir. Esta etapa de descubrimiento es lo que separa un proyecto exitoso de uno que hay que rehacer.</p>
          <p class="sh__copy">Trabajamos con entregables claros en cada fase: wireframes aprobados antes del diseño, diseño aprobado antes del desarrollo, y staging completo antes del lanzamiento. Tú siempre sabes en qué etapa estamos, qué sigue y cuándo termina. Al lanzar, te capacitamos para gestionar tu propio contenido y te entregamos documentación técnica completa del proyecto.</p>
        </div>
      </div>
      <div class="process-grid">
        {proceso.map(s => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 6: TESTIMONIOS -->
  <section class="testimonials-section">
    <div class="container">
      <div class="sh">
        <div class="sh__left">
          <span class="eyebrow">Testimonios</span>
          <h2 class="section-title">Lo que dicen nuestros clientes.</h2>
        </div>
        <div class="sh__right">
          <p class="sh__copy">Los mejores indicadores de calidad no son los que nosotros mismos decimos — son los resultados que nuestros clientes reportan semanas después de lanzar. Empresas mexicanas de sectores tan distintos como gastronomía, servicios profesionales, retail y manufactura han encontrado en OrigenLab un socio tecnológico confiable que entrega lo prometido en tiempo y forma.</p>
          <p class="sh__copy">Más del 70% de nuestros proyectos provienen de referidos o de clientes que regresan para un segundo o tercer proyecto. Eso no ocurre por accidente — ocurre porque nuestro enfoque va más allá de entregar código: acompañamos el crecimiento digital de cada cliente con soporte, métricas y estrategia a largo plazo.</p>
        </div>
      </div>
      <div class="testimonials-grid">
        {testimonios.map(t => <TestimonialCard {...t} />)}
      </div>
    </div>
  </section>

  <!-- SECCIÓN 7: CTA FINAL -->
  <CTASection />
</BaseLayout>

<style>
  /* --- Section Header 2 columnas (sh) --- */
  .sh {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .sh--dark {
    border-bottom-color: var(--border-dark);
  }

  .sh__left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .sh__left .eyebrow,
  .sh__left .eyebrow-dark {
    margin-bottom: 1.25rem;
  }

  .sh__left .section-title,
  .sh__left .section-title-dark {
    text-align: left;
    margin-bottom: .75rem;
  }

  .sh__left .section-subtitle {
    text-align: left;
    margin: 0;
    max-width: 100%;
  }

  .sh__right {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-top: .25rem;
  }

  .sh__copy {
    font-size: 15px;
    line-height: 1.8;
    color: var(--text-muted);
    margin: 0;
  }

  .sh__copy--dark {
    color: rgba(255,255,255,0.55);
  }

  @media (max-width: 900px) {
    .sh {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* --- Utilidades de sección --- */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.3rem 0.875rem;
    border: 1px solid var(--accent);
    border-radius: 980px;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 21px;
    font-weight: 400;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* --- SECCIÓN 2: CTA BAR --- */
  .cta-bar {
    background: var(--text);
    padding: 2.5rem 0;
  }

  .cta-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-bar__text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .cta-bar__headline {
    font-size: 22px;
    font-weight: 600;
    color: #FFFFFF;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .cta-bar__sub {
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }

  .cta-bar__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .cta-bar__link {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .cta-bar__link:hover {
    color: #FFFFFF;
  }

  /* --- SECCIÓN 3: SERVICIOS --- */
  .services-section {
    background: var(--bg);
    padding: var(--section-py) 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  /* --- SECCIÓN 4: POR QUÉ ELEGIRNOS --- */
  .why-section {
    background: var(--bg-dark);
    padding: var(--section-py) 0;
  }

  .section-header-dark {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .eyebrow-dark {
    display: inline-block;
    padding: 0.3rem 0.875rem;
    border: 1px solid var(--accent);
    border-radius: 980px;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .section-title-dark {
    font-size: clamp(2rem, 5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-on-dark);
    line-height: 1.1;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  /* --- SECCIÓN 5: PROCESO --- */
  .process-section {
    background: var(--bg-alt);
    padding: var(--section-py) 0;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  /* --- SECCIÓN 6: TESTIMONIOS --- */
  .testimonials-section {
    background: var(--bg);
    padding: var(--section-py) 0;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  /* --- RESPONSIVE --- */
  @media (max-width: 1024px) {
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cta-bar__inner {
      flex-direction: column;
      text-align: center;
    }
    .cta-bar__actions {
      justify-content: center;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .section-subtitle {
      font-size: 17px;
    }
  }
</style>
