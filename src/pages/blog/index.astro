---
import PageLayout from '../../layouts/PageLayout.astro';

const articulos = [
  {
    slug: "por-que-elegir-astro-para-tu-sitio",
    titulo: "¿Por qué Astro es la mejor opción para tu sitio web en 2025?",
    resumen: "Exploramos por qué Astro supera a WordPress y otros CMS en velocidad, SEO y costo de mantenimiento.",
    fecha: "2025-02-10",
    categoria: "Tecnología"
  },
  {
    slug: "seo-local-cdmx",
    titulo: "SEO local para empresas en CDMX: guía práctica",
    resumen: "Cómo posicionar tu negocio en Google Maps y búsquedas locales de Ciudad de México.",
    fecha: "2025-01-28",
    categoria: "SEO"
  },
  {
    slug: "velocidad-sitio-web-ventas",
    titulo: "Cómo la velocidad de tu sitio impacta directamente tus ventas",
    resumen: "Cada segundo de carga que ahorras puede significar un 7% más de conversiones. Te explicamos cómo.",
    fecha: "2025-01-15",
    categoria: "Rendimiento"
  }
];

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<PageLayout
  title="Blog"
  eyebrow="Blog"
  description="Artículos sobre desarrollo web, SEO y marketing digital para empresas mexicanas."
  subtitle="Contenido práctico y sin tecnicismos, pensado para dueños de negocio que quieren entender cómo mejorar su presencia digital. Publicamos con frecuencia — guarda esta página o suscríbete para no perderte ningún artículo."
  keywords="blog desarrollo web México, SEO para empresas, tips web, OrigenLab blog"
>
  <div class="blog-grid">
    {articulos.map(art => (
      <article class="blog-card">
        <div class="blog-card-header">
          <span class="blog-cat">{art.categoria}</span>
          <time datetime={art.fecha}>{formatDate(art.fecha)}</time>
        </div>
        <h2><a href={`/blog/${art.slug}`}>{art.titulo}</a></h2>
        <p>{art.resumen}</p>
        <a href={`/blog/${art.slug}`} class="read-more">Leer artículo →</a>
      </article>
    ))}
  </div>

  <div class="blog-cta">
    <p>¿Quieres aprender más? Suscríbete a nuestra newsletter.</p>
    <form class="newsletter-form" action="#" method="POST">
      <input type="email" placeholder="tu@correo.com" required />
      <button type="submit">Suscribirme</button>
    </form>
  </div>
</PageLayout>

<style>
  .blog-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .blog-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    transition: border-color 0.3s;
  }

  .blog-card:hover {
    border-color: var(--color-accent);
  }

  .blog-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .blog-cat {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    padding: 0.2rem 0.75rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .blog-card h2 {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .blog-card h2 a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .blog-card h2 a:hover {
    color: var(--color-accent);
  }

  .blog-card p {
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .read-more {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }

  .read-more:hover {
    opacity: 0.7;
  }

  .blog-cta {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border-radius: 16px;
    border: 1px solid var(--color-border);
  }

  .blog-cta p {
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .newsletter-form {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .newsletter-form input {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.95rem;
    min-width: 260px;
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .newsletter-form button {
    background: var(--color-accent);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .newsletter-form button:hover {
    opacity: 0.85;
  }
</style>
