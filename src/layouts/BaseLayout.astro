---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Topbar from '../components/Topbar.astro';
import WaBubble from '../components/WaBubble.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = "OrigenLab — Agencia de desarrollo web profesional en México. Sitios rápidos, modernos y optimizados para SEO que generan resultados.",
  keywords = "desarrollo web, diseño web, agencia web México, sitios web profesionales, SEO, tiendas en línea, landing pages",
  ogImage = "/og-image.jpg",
  canonical,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title === "OrigenLab" ? "OrigenLab — Sitios web que generan resultados" : `${title} | OrigenLab`;
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="OrigenLab" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "OrigenLab",
      "url": "https://origenlab.mx",
      "logo": "https://origenlab.mx/logo.svg",
      "description": "Agencia de desarrollo web profesional en México. Sitios web que generan resultados.",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "MX"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+5547868402",
        "contactType": "sales",
        "availableLanguage": "Spanish"
      },
      "sameAs": []
    })} />

    <!-- TruConversion -->
    <script is:inline>
      var _tip = _tip || [];
      (function(d,s,id){
        var js, tjs = d.getElementsByTagName(s)[0];
        if(d.getElementById(id)) { return; }
        js = d.createElement(s); js.id = id;
        js.async = true;
        js.src = d.location.protocol + '//app.truconversion.com/ti-js/62670/e9e44.js';
        tjs.parentNode.insertBefore(js, tjs);
      }(document, 'script', 'ti-js'));
    </script>
  </head>
  <body>
    <Topbar />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WaBubble />
  </body>
</html>
